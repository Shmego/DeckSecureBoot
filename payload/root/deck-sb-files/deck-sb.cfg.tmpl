function d_rf_set {
    if [ x$d_pt = xself ]; then
        set d_rf_u=$1
    elif [ x$d_pt = xA ]; then
        set d_ra_u=$1
    elif [ x$d_pt = xB ]; then
        set d_rb_u=$1
    fi
}

function d_ef_set {
    if [ x$d_pt = xself ]; then
        set d_ef_s=$1
    elif [ x$d_pt = xA ]; then
        set d_ef_a=$1
    elif [ x$d_pt = xB ]; then
        set d_ef_b=$1
    fi
}

function d_vr_set {
    if [ x$d_pt = xself ]; then
        set d_vr_s=$1
    elif [ x$d_pt = xA ]; then
        set d_vr_a=$1
    elif [ x$d_pt = xB ]; then
        set d_vr_b=$1
    fi
}

function d_hm_set {
    if [ x$d_hm = x ]; then
        set d_hm=$1
    fi
}

function d_ep_set {
    if [ x$d_ep = x ]; then
        set d_ep=$1
    fi
}

function d_ap_ps {
    if [ x$d_ps_src != x ]; then
        if [ x$d_pt = xself ]; then
            set d_src_s=$d_ps_src
        elif [ x$d_pt = xA ]; then
            set d_src_a=$d_ps_src
        elif [ x$d_pt = xB ]; then
            set d_src_b=$d_ps_src
        elif [ x$d_pt = xall ]; then
            set d_src_all=$d_ps_src
        elif [ x$d_pt = xshared ]; then
            set d_src_sh=$d_ps_src
        fi
    fi
    if [ x$d_ps_rf != x ]; then
        d_rf_set $d_ps_rf
    fi
    if [ x$d_ps_ef != x ]; then
        d_ef_set $d_ps_ef
    fi
    if [ x$d_ps_vr != x ]; then
        d_vr_set $d_ps_vr
    fi
    if [ x$d_ps_hm != x ]; then
        d_hm_set $d_ps_hm
    fi
    if [ x$d_ps_ep != x ]; then
        d_ep_set $d_ps_ep
    fi
}

function d_dbg_ps {
    if [ x$d_ps_src != x ]; then
        echo "DeckSB: partset src $d_ps_src"
    fi
    if [ x$d_ps_rf != x ]; then
        echo "DeckSB: partset rootfs $d_ps_rf"
    else
        echo "DeckSB: partset rootfs missing"
    fi
    if [ x$d_ps_ef != x ]; then
        echo "DeckSB: partset efi $d_ps_ef"
    else
        echo "DeckSB: partset efi missing"
    fi
    if [ x$d_ps_vr != x ]; then
        echo "DeckSB: partset var $d_ps_vr"
    else
        echo "DeckSB: partset var missing"
    fi
    if [ x$d_ps_hm != x ]; then
        echo "DeckSB: partset home $d_ps_hm"
    else
        echo "DeckSB: partset home missing"
    fi
    if [ x$d_ps_ep != x ]; then
        echo "DeckSB: partset esp $d_ps_ep"
    else
        echo "DeckSB: partset esp missing"
    fi
}

function d_try_psf {
    if [ x$1 = x ]; then
        return 1
    fi
    d_ps $1
    if [ x$d_ps_ok = x1 ]; then
        d_ap_ps
        d_dbg_ps
        return 0
    fi
    return 1
}

function d_try_psr {
    if [ x$d_pr = x ]; then
        return 1
    fi
    if [ -f "($d_pr)$d_ps_p/$d_pt" ]; then
        if d_try_psf "($d_pr)$d_ps_p/$d_pt"; then
            echo "DeckSB: loaded partset $d_pt from $d_ps_p/$d_pt"
            return 0
        fi
        echo "DeckSB: failed to parse $d_ps_p/$d_pt"
    fi
    return 1
}

function d_ld_ps {
    if [ x$1 != x ]; then
        set d_pt=$1
    fi
    set d_pr=
    if [ x$d_pt = x ]; then
        echo "DeckSB: partset target missing"
        return
    fi
    if [ x$d_ps_p = x ] || [ x$d_ps_p = x__DECK_SB_PARTSETS_HINT_PATH__ ]; then
        set d_ps_p=/SteamOS/partsets
    fi
    if [ x$d_ps_f = x__DECK_SB_PARTSETS_HINT_FSUUID__ ]; then
        set d_ps_f=
    fi
    echo "DeckSB: trying partset target $d_pt"
    if [ x$d_ps_f != x ]; then
        if search --no-floppy --fs-uuid --set=d_pr $d_ps_f; then
            if d_try_psr; then
                return
            fi
        fi
    fi
    if search --no-floppy --file $d_ps_p/$d_pt --set=d_pr; then
        if d_try_psr; then
            return
        fi
    fi
    if search --file $d_ps_p/$d_pt --set=d_pr; then
        if d_try_psr; then
            return
        fi
    fi
    if [ x$d_pr != x ]; then
        echo "DeckSB: partset $d_pt parse failed on $d_pr"
    else
        echo "DeckSB: partset $d_pt not found"
    fi
}

function d_ld_cf {
    set d_sl=
    set d_rs=
    set d_cr=
    set d_sr=$root
    set d_sp=$prefix
    if search --no-floppy --file /SteamOS/conf/A.conf --set=d_cr; then
        d_cf ($d_cr)/SteamOS/conf
    elif search --no-floppy --file /EFI/SteamOS/conf/A.conf --set=d_cr; then
        d_cf ($d_cr)/EFI/SteamOS/conf
    elif search --no-floppy --file /efi/SteamOS/conf/A.conf --set=d_cr; then
        d_cf ($d_cr)/efi/SteamOS/conf
    fi
    if [ x$d_sr != x ]; then
        set root=$d_sr
    else
        set root=
    fi
    if [ x$d_sp != x ]; then
        set prefix=$d_sp
    else
        set prefix=
    fi
    if [ x$d_sl != x ]; then
        if [ x$d_rs != x ]; then
            echo "DeckSB: bootconf slot $d_sl ($d_rs)"
        else
            echo "DeckSB: bootconf slot $d_sl"
        fi
    else
        echo "DeckSB: bootconf missing"
    fi
}

function d_res_rf {
    if [ x$d_bn != x1 ]; then
        return
    fi
    set d_rf_u=
    set d_ra_u=
    set d_rb_u=
    set d_lbl=
    set d_rdy=
    set d_src_s=
    set d_src_a=
    set d_src_b=
    set d_src_all=
    set d_src_sh=

    set d_pt=self
    d_ld_ps
    set d_pt=A
    d_ld_ps
    set d_pt=B
    d_ld_ps
    set d_pt=all
    d_ld_ps
    set d_pt=shared
    d_ld_ps
    d_ld_cf

    if [ x$d_sl != x ]; then
        if [ x$d_rs != x ]; then
            echo "DeckSB: slot preference $d_sl via $d_rs"
        else
            echo "DeckSB: slot preference $d_sl"
        fi
    else
        echo "DeckSB: slot preference unavailable"
    fi

    if [ x$d_src_s != x ]; then
        echo "DeckSB: source self $d_src_s"
    fi
    if [ x$d_src_a != x ]; then
        echo "DeckSB: source A $d_src_a"
    fi
    if [ x$d_src_b != x ]; then
        echo "DeckSB: source B $d_src_b"
    fi
    if [ x$d_src_all != x ]; then
        echo "DeckSB: source all $d_src_all"
    fi
    if [ x$d_src_sh != x ]; then
        echo "DeckSB: source shared $d_src_sh"
    fi

    if [ x$d_rf_u != x ]; then
        echo "DeckSB: self rootfs $d_rf_u"
    else
        echo "DeckSB: self rootfs missing"
    fi
    if [ x$d_ra_u != x ]; then
        echo "DeckSB: A rootfs $d_ra_u"
    else
        echo "DeckSB: A rootfs missing"
    fi
    if [ x$d_rb_u != x ]; then
        echo "DeckSB: B rootfs $d_rb_u"
    else
        echo "DeckSB: B rootfs missing"
    fi

    if [ x$d_sl = xA ] && [ x$d_ra_u != x ]; then
        set d_lbl=A
    elif [ x$d_sl = xB ] && [ x$d_rb_u != x ]; then
        set d_lbl=B
    elif [ x$d_rf_u != x ]; then
        if [ x$d_rf_u = x$d_ra_u ]; then
            set d_lbl=A
        elif [ x$d_rf_u = x$d_rb_u ]; then
            set d_lbl=B
        else
            set d_lbl=?
        fi
    fi
    if [ x$d_lbl != x ]; then
        echo "Booting SteamOS $d_lbl..."
    else
        echo "Booting SteamOS..."
    fi

    if [ x$d_lbl = xA ]; then
        set d_ef_u=$d_ef_a
        set d_vr_u=$d_vr_a
    elif [ x$d_lbl = xB ]; then
        set d_ef_u=$d_ef_b
        set d_vr_u=$d_vr_b
    else
        set d_ef_u=
        set d_vr_u=
    fi

    echo "DeckSB: map A rootfs=$d_ra_u efi=$d_ef_a var=$d_vr_a"
    echo "DeckSB: map B rootfs=$d_rb_u efi=$d_ef_b var=$d_vr_b"
    echo "DeckSB: map shared home=$d_hm esp=$d_ep"
    echo "DeckSB: chosen slot=$d_lbl efi=$d_ef_u var=$d_vr_u home=$d_hm esp=$d_ep"

    if [ x$d_rf_u != x ]; then
        set d_ar_r="root=PARTUUID=$d_rf_u"
    else
        set d_ar_r=
    fi
    if [ x$d_ef_u != x ]; then
        set d_ar_e="rd.steamos.efi=PARTUUID=$d_ef_u"
    else
        set d_ar_e=
    fi
    if [ x$d_vr_u != x ]; then
        set d_ar_v="rd.steamos.var=PARTUUID=$d_vr_u"
    else
        set d_ar_v=
    fi
    if [ x$d_hm != x ]; then
        set d_ar_h="rd.steamos.home=PARTUUID=$d_hm"
    else
        set d_ar_h=
    fi
    if [ x$d_ep != x ]; then
        set d_ar_s="rd.steamos.esp=PARTUUID=$d_ep"
    else
        set d_ar_s=
    fi

    if [ x$d_ar_r != x ]; then
        echo "DeckSB: root arg $d_ar_r"
    else
        echo "DeckSB: root arg missing"
    fi
    if [ x$d_ar_e != x ]; then
        echo "DeckSB: efi arg $d_ar_e"
    else
        echo "DeckSB: efi arg missing"
    fi
    if [ x$d_ar_v != x ]; then
        echo "DeckSB: var arg $d_ar_v"
    else
        echo "DeckSB: var arg missing"
    fi
    if [ x$d_ar_h != x ]; then
        echo "DeckSB: home arg $d_ar_h"
    else
        echo "DeckSB: home arg missing"
    fi
    if [ x$d_ar_s != x ]; then
        echo "DeckSB: esp arg $d_ar_s"
    else
        echo "DeckSB: esp arg missing"
    fi

    if [ x$d_lbl = xA ]; then
        set d_rf_f=$d_ra_f
    elif [ x$d_lbl = xB ]; then
        set d_rf_f=$d_rb_f
    else
        set d_rf_f=
    fi

    if [ x$d_rf_f != x ]; then
        search --no-floppy --fs-uuid --set=root $d_rf_f
        if [ x$root != x ]; then
            echo "DeckSB: root set via fs-uuid $d_rf_f"
            set d_rdy=1
        else
            echo "DeckSB: unable to find fs-uuid $d_rf_f"
        fi
    else
        echo "DeckSB: missing fs-uuid mapping for $d_lbl"
    fi
}


menuentry 'SteamOS SB (shimless)' {
    # IMPORTANT: do NOT reset gfxpayload or terminal here.
    # We want to keep the hi-res framebuffer and gfxterm.
    
    background_image $cmdpath/boot.png
    
    # Force a repaint to the framebuffer

    insmod part_gpt
    insmod search_fs_uuid
    insmod fat
    insmod btrfs
    insmod gzio
__DECK_SB_KERNEL_BLOCK__
}

# Automatically detect Windows, Clover, and the stock SteamOS loader when present
set deck_win_path=''
if search --file /EFI/Microsoft/Boot/bootmgfw.efi --set=deck_win; then
    set deck_win_path='/EFI/Microsoft/Boot/bootmgfw.efi'
elif search --file /EFI/Microsoft/bootmgfw.efi --set=deck_win; then
    set deck_win_path='/EFI/Microsoft/bootmgfw.efi'
fi

if test -n "$deck_win_path"; then
    menuentry 'Windows Boot Manager' {
        insmod part_gpt
        insmod fat
        insmod chain
        search --no-floppy --file $deck_win_path --set=root
        echo 'Tip: Boot Windows directly from the BIOS menu (Vol- + Power) to avoid Secure Boot prompts.'
        echo 'If you use Clover: press Vol+ + Power, then Boot From File -> efi/Microsoft/bootmgfw.efi'
        echo ''
        echo 'Recommended: Disable BitLocker so chainloading from this menu or Clover can load Windows correctly.'
        sleep 2
        set gfxpayload=text
        terminal_output console
        chainloader $deck_win_path
    }
fi

set deck_clover_path=''
if search --file /EFI/CLOVER/CLOVERX64.efi --set=deck_clover; then
    set deck_clover_path='/EFI/CLOVER/CLOVERX64.efi'
elif search --file /EFI/Clover/CLOVERX64.efi --set=deck_clover; then
    set deck_clover_path='/EFI/Clover/CLOVERX64.efi'
elif search --file /efi/clover/CLOVERX64.efi --set=deck_clover; then
    set deck_clover_path='/efi/clover/CLOVERX64.efi'
elif search --file /EFI/CLOVER/cloverx64.efi --set=deck_clover; then
    set deck_clover_path='/EFI/CLOVER/cloverx64.efi'
elif search --file /EFI/Clover/cloverx64.efi --set=deck_clover; then
    set deck_clover_path='/EFI/Clover/cloverx64.efi'
elif search --file /efi/clover/cloverx64.efi --set=deck_clover; then
    set deck_clover_path='/efi/clover/cloverx64.efi'
fi

if test -n "$deck_clover_path"; then
    menuentry 'Clover Bootloader' {
        set gfxpayload=text
        terminal_output console
        insmod part_gpt
        insmod fat
        insmod chain
        search --no-floppy --file $deck_clover_path --set=root
        chainloader $deck_clover_path
    }
fi

set deck_steamcl_path=''
if search --file /EFI/steamos/steamcl.efi --set=deck_steamcl; then
    set deck_steamcl_path='/EFI/steamos/steamcl.efi'
elif search --file /efi/steamos/steamcl.efi --set=deck_steamcl; then
    set deck_steamcl_path='/efi/steamos/steamcl.efi'
fi

if test -n "$deck_steamcl_path"; then
    menuentry 'SteamOS Official Bootloader' {
        set gfxpayload=text
        terminal_output console
        insmod part_gpt
        insmod fat
        insmod chain
        search --no-floppy --file $deck_steamcl_path --set=root
        chainloader $deck_steamcl_path
    }
fi

set deck_iso_file='/usr/local/share/deck-sb/arch/boot/x86_64/vmlinuz-linux'
set deck_iso_uuid=''
set deck_iso_devpath=''
if search --file $deck_iso_file --set=deck_iso_probe; then
    menuentry 'Deck Secure Boot Tools (On Disk)' {
        set gfxpayload=text
        terminal_output console
        insmod part_gpt
        insmod btrfs
        insmod gzio
        insmod probe
        search --no-floppy --file $deck_iso_file --set=deck_iso
        if [ -z "$deck_iso" ]; then
            echo 'Unable to locate Deck SB files on disk.'
            sleep 3
        else
            set root=$deck_iso
            probe --set=deck_iso_uuid --fs-uuid ($deck_iso)
            if [ -n "$deck_iso_uuid" ]; then
                set deck_iso_devpath="/dev/disk/by-uuid/$deck_iso_uuid"
            fi
        fi
        if [ -n "$deck_iso_uuid" ]; then
            echo 'Deck SB on-disk debug:'
            echo "  device: $deck_iso"
            echo "  uuid:   $deck_iso_uuid"
            set deck_iso_kernel="/usr/local/share/deck-sb/arch/boot/x86_64/vmlinuz-linux"
            set deck_iso_initrd="/usr/local/share/deck-sb/arch/boot/x86_64/initramfs-linux.img"
            set deck_iso_sfs="/usr/local/share/deck-sb/arch/x86_64/airootfs.sfs"
            if [ -f "($deck_iso)$deck_iso_kernel" ]; then
                echo "  kernel: ($deck_iso)$deck_iso_kernel [OK]"
            else
                echo "  kernel: ($deck_iso)$deck_iso_kernel [MISSING]"
            fi
            if [ -f "($deck_iso)$deck_iso_initrd" ]; then
                echo "  initrd: ($deck_iso)$deck_iso_initrd [OK]"
            else
                echo "  initrd: ($deck_iso)$deck_iso_initrd [MISSING]"
            fi
            echo "  archisobasedir=usr/local/share/deck-sb/arch"
            echo "  archisodevice=$deck_iso_devpath"
            echo "  img_dev=$deck_iso_devpath"
            if [ -f "($deck_iso)$deck_iso_sfs" ]; then
                echo "  img_loop: ($deck_iso)$deck_iso_sfs [OK]"
            else
                echo "  img_loop: ($deck_iso)$deck_iso_sfs [MISSING]"
            fi
            sleep 3
            linux ($deck_iso)/usr/local/share/deck-sb/arch/boot/x86_64/vmlinuz-linux archisobasedir=usr/local/share/deck-sb/arch archisodevice=$deck_iso_devpath img_dev=$deck_iso_devpath img_loop=/usr/local/share/deck-sb/arch/x86_64/airootfs.sfs copytoram=n
            initrd ($deck_iso)/usr/local/share/deck-sb/arch/boot/x86_64/initramfs-linux.img
        else
            echo 'Unable to determine filesystem UUID for deck-sb files.'
            sleep 3
        fi
    }
fi
