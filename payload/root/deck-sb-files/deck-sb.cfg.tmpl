    fi
}

function decksb_load_partset {
    set deck_partset_target=$1
    if search --file /SteamOS/partsets/$1 --set=deck_partset_root; then
        if source ($deck_partset_root)/SteamOS/partsets/$1; then
            echo "DeckSB: loaded partset $1 from /SteamOS/partsets/$1"
        else
            echo "DeckSB: failed to parse /SteamOS/partsets/$1"
        fi
        return
    elif search --file /EFI/SteamOS/partsets/$1 --set=deck_partset_root; then
        if source ($deck_partset_root)/EFI/SteamOS/partsets/$1; then
            echo "DeckSB: loaded partset $1 from /EFI/SteamOS/partsets/$1"
        else
            echo "DeckSB: failed to parse /EFI/SteamOS/partsets/$1"
        fi
        return
    elif search --file /efi/SteamOS/partsets/$1 --set=deck_partset_root; then
        if source ($deck_partset_root)/efi/SteamOS/partsets/$1; then
            echo "DeckSB: loaded partset $1 from /efi/SteamOS/partsets/$1"
        else
            echo "DeckSB: failed to parse /efi/SteamOS/partsets/$1"
        fi
        return
    fi
    echo "DeckSB: partset $1 not found"
}

function decksb_resolve_rootfs {
    set deck_rootfs_uuid=
    set deck_rootfs_a_uuid=
    set deck_rootfs_b_uuid=
    set deck_rootfs_label=
    set deck_rootfs_ready=

    decksb_load_partset self
    decksb_load_partset A
    decksb_load_partset B
    decksb_load_partset all
    decksb_load_partset shared

    if [ x$deck_rootfs_uuid != x ]; then
        echo "DeckSB: self rootfs $deck_rootfs_uuid"
    else
        echo "DeckSB: self rootfs missing"
    fi
    if [ x$deck_rootfs_a_uuid != x ]; then
        echo "DeckSB: A rootfs $deck_rootfs_a_uuid"
    else
        echo "DeckSB: A rootfs missing"
    fi
    if [ x$deck_rootfs_b_uuid != x ]; then
        echo "DeckSB: B rootfs $deck_rootfs_b_uuid"
    else
        echo "DeckSB: B rootfs missing"
    fi

    if [ x$deck_rootfs_uuid != x ]; then
        if [ x$deck_rootfs_uuid = x$deck_rootfs_a_uuid ]; then
            set deck_rootfs_label=A
        elif [ x$deck_rootfs_uuid = x$deck_rootfs_b_uuid ]; then
            set deck_rootfs_label=B
        else
            set deck_rootfs_label=?
        fi
    fi
    if [ x$deck_rootfs_label != x ]; then
        echo "Booting SteamOS $deck_rootfs_label..."
    else
        echo "Booting SteamOS..."
    fi

    if [ x$deck_rootfs_label = xA ]; then
        set deck_efi_uuid=$deck_partset_efi_a
        set deck_var_uuid=$deck_partset_var_a
    elif [ x$deck_rootfs_label = xB ]; then
        set deck_efi_uuid=$deck_partset_efi_b
        set deck_var_uuid=$deck_partset_var_b
    else
        set deck_efi_uuid=
        set deck_var_uuid=
    fi

    if [ x$deck_rootfs_uuid != x ]; then
        set deck_root_arg="root=PARTUUID=$deck_rootfs_uuid"
    else
        set deck_root_arg=
    fi
    if [ x$deck_efi_uuid != x ]; then
        set deck_efi_arg="rd.steamos.efi=PARTUUID=$deck_efi_uuid"
    else
        set deck_efi_arg=
    fi
    if [ x$deck_var_uuid != x ]; then
        set deck_var_arg="rd.steamos.var=PARTUUID=$deck_var_uuid"
    else
        set deck_var_arg=
    fi
    if [ x$deck_partset_home != x ]; then
        set deck_home_arg="rd.steamos.home=PARTUUID=$deck_partset_home"
    else
        set deck_home_arg=
    fi
    if [ x$deck_partset_esp != x ]; then
        set deck_esp_arg="rd.steamos.esp=PARTUUID=$deck_partset_esp"
    else
        set deck_esp_arg=
    fi

    if [ x$deck_root_arg != x ]; then
        echo "DeckSB: root arg $deck_root_arg"
    else
        echo "DeckSB: root arg missing"
    fi
    if [ x$deck_efi_arg != x ]; then
        echo "DeckSB: efi arg $deck_efi_arg"
    else
        echo "DeckSB: efi arg missing"
    fi
    if [ x$deck_var_arg != x ]; then
        echo "DeckSB: var arg $deck_var_arg"
    else
        echo "DeckSB: var arg missing"
    fi
    if [ x$deck_home_arg != x ]; then
        echo "DeckSB: home arg $deck_home_arg"
    else
        echo "DeckSB: home arg missing"
    fi
    if [ x$deck_esp_arg != x ]; then
        echo "DeckSB: esp arg $deck_esp_arg"
    else
        echo "DeckSB: esp arg missing"
    fi

    if [ x$deck_rootfs_label = xA ]; then
        set deck_rootfs_fsuuid=$deck_rootfs_a_fsuuid
    elif [ x$deck_rootfs_label = xB ]; then
        set deck_rootfs_fsuuid=$deck_rootfs_b_fsuuid
    else
        set deck_rootfs_fsuuid=
    fi

    if [ x$deck_rootfs_fsuuid != x ]; then
        search --no-floppy --fs-uuid --set=root $deck_rootfs_fsuuid
        if [ x$root != x ]; then
            echo "DeckSB: root set via fs-uuid $deck_rootfs_fsuuid"
            set deck_rootfs_ready=1
        else
            echo "DeckSB: unable to find fs-uuid $deck_rootfs_fsuuid"
        fi
    else
        echo "DeckSB: missing fs-uuid mapping for $deck_rootfs_label"
    fi
}

