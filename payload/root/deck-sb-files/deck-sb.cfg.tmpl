function rootfs {
    if [ x$deck_partset_target = xself ]; then
        set deck_rootfs_uuid=$1
    elif [ x$deck_partset_target = xA ]; then
        set deck_rootfs_a_uuid=$1
    elif [ x$deck_partset_target = xB ]; then
        set deck_rootfs_b_uuid=$1
    fi
}

function efi {
    if [ x$deck_partset_target = xself ]; then
        set deck_partset_efi=$1
    elif [ x$deck_partset_target = xA ]; then
        set deck_partset_efi_a=$1
    elif [ x$deck_partset_target = xB ]; then
